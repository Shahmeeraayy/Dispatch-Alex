COMPANY_STREET_ADDRESS=123 Dispatch Ave
COMPANY_CITY=Quebec
COMPANY_STATE=QC
COMPANY_ZIP_CODE=G1A 1A1
COMPANY_PHONE=+1-418-555-0100
COMPANY_EMAIL=billing@sm2dispatch.com
COMPANY_WEBSITE=https://www.sm2dispatch.com
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REDIRECT_URI=
QB_ENV=sandbox
