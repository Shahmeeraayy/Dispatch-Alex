APP_ENV=development
# Local SQLite (dev):
DATABASE_URL=sqlite:///./project_local.db
# PostgreSQL (shared server) example:
# DATABASE_URL=postgresql+psycopg://postgres:your_password@localhost:5432/sm2_dispatch
# Hosted Postgres URLs like postgres://... are also accepted and auto-normalized.
JWT_SECRET_KEY=change-me-dev-only
JWT_ALGORITHM=HS256
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
COMPANY_LOGO_URL=
